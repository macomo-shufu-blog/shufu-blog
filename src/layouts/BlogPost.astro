---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, readingTime, headings } = Astro.props;
const tocHeadings = (headings ?? []).filter((h: {depth: number}) => h.depth === 2 || h.depth === 3);

const catMap: Record<string, { label: string; bg: string; color: string; dot: string }> = {
  money: { label: 'お金', bg: '#F0E4D4', color: '#8A6A3E', dot: '#C49A6A' },
  study: { label: '学び', bg: '#DDE3D4', color: '#4F6041', dot: '#7A8B6A' },
  family: { label: '子育て', bg: '#EDDCDC', color: '#7A5252', dot: '#A67F7F' },
};
const cat = catMap[category || 'money'] || catMap.money;

const dateStr = pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'2-digit',day:'2-digit'}).replace(/\//g, '.');
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .layout {
        max-width: var(--layout-max);
        margin: 0 auto;
        padding: 48px 24px 60px;
        display: grid;
        grid-template-columns: 1fr var(--sidebar-width);
        gap: 40px;
      }
      article {
        min-width: 0;
      }
      .article-meta {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        font-size: 12px;
        color: var(--color-ink-mute);
      }
      .tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
        padding: 3px 10px;
        border-radius: var(--radius-xs);
      }
      .tag-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .article-title {
        font-family: var(--font-serif);
        font-size: 34px;
        font-weight: 500;
        color: var(--color-ink);
        letter-spacing: 0.04em;
        line-height: 1.4;
        margin: 0 0 28px;
      }
      .prose {
        max-width: var(--content-max);
        font-size: 16px;
        line-height: 1.95;
        color: var(--color-ink);
      }
      .prose h2 {
        font-family: var(--font-serif);
        font-size: 22px;
        font-weight: 500;
        color: var(--color-ink);
        margin: 48px 0 16px;
        letter-spacing: 0.04em;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--color-border);
      }
      .prose h3 {
        font-family: var(--font-serif);
        font-size: 18px;
        font-weight: 500;
        color: var(--color-ink);
        margin: 28px 0 12px;
      }
      .prose p {
        margin: 0 0 28px;
      }
      .prose ul, .prose ol {
        margin: 0 0 20px;
        padding-left: 1.5em;
      }
      .prose li { margin-bottom: 8px; }
      .prose blockquote {
        background: var(--color-surface-warm);
        border-left: 3px solid var(--color-accent);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        padding: 16px 20px;
        margin: 32px 0;
        font-size: 14px;
        color: var(--color-ink);
        line-height: 1.9;
      }
      .prose blockquote p { margin: 0 0 8px; }
      .prose blockquote p:last-child { margin: 0; }
      .prose hr {
        border: none;
        border-top: 1px solid var(--color-border);
        margin: 40px 0;
      }
      /* テーブル */
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 32px;
        font-size: 14px;
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid var(--color-border);
      }
      .prose th {
        background: var(--color-surface-warm);
        color: var(--color-ink);
        font-weight: 600;
        padding: 12px 16px;
        border-bottom: 2px solid var(--color-border);
        text-align: left;
        font-family: var(--font-serif);
        font-size: 13px;
        letter-spacing: 0.03em;
      }
      .prose td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--color-border-soft);
        color: var(--color-ink);
        line-height: 1.7;
      }
      .prose tr:last-child td { border-bottom: none; }
      .prose tr:nth-child(even) td {
        background: var(--color-paper-light);
      }
      /* 太字を目立たせる */
      .prose strong {
        color: var(--color-ink);
        font-weight: 600;
      }
      /* リストをきれいに */
      .prose ul { list-style: none; padding-left: 0; }
      .prose ul li {
        padding-left: 1.4em;
        position: relative;
      }
      .prose ul li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.65em;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--color-accent);
        opacity: 0.7;
      }
      .prose ol { padding-left: 1.5em; }
      .prose ol li::marker {
        color: var(--color-accent);
        font-weight: 600;
      }

      /* ポイントボックス */
      .point-box {
        background: #F0F4EC;
        border: 1px solid #C8D8B8;
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin: 32px 0;
      }
      .point-box .box-title {
        font-family: var(--font-serif);
        font-size: 14px;
        font-weight: 600;
        color: #4F6041;
        letter-spacing: 0.05em;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .point-box ul { margin: 0; }
      .point-box li { font-size: 14px; color: var(--color-ink); }

      /* まとめボックス */
      .summary-box {
        background: var(--color-surface-warm);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin: 32px 0;
      }
      .summary-box .box-title {
        font-family: var(--font-serif);
        font-size: 14px;
        font-weight: 600;
        color: var(--color-accent);
        letter-spacing: 0.05em;
        margin-bottom: 12px;
      }

      /* CTAボックス */
      .cta-box {
        background: linear-gradient(135deg, #F5EDE3, #FAF3EC);
        border: 1px solid #D9C4AA;
        border-radius: var(--radius-lg);
        padding: 24px 28px;
        margin: 40px 0;
        text-align: center;
      }
      .cta-box .cta-title {
        font-family: var(--font-serif);
        font-size: 17px;
        color: var(--color-ink);
        margin-bottom: 8px;
        font-weight: 500;
      }
      .cta-box .cta-desc {
        font-size: 13px;
        color: var(--color-ink-soft);
        line-height: 1.7;
        margin-bottom: 16px;
      }
      .cta-box .cta-btn {
        display: inline-block;
        background: var(--color-accent);
        color: #fff;
        border-radius: var(--radius-md);
        padding: 12px 28px;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-decoration: none;
        transition: background var(--duration-base) var(--easing-standard);
      }
      .cta-box .cta-btn:hover { background: var(--color-accent-hover); color: #fff; }
      .cta-box .cta-note {
        font-size: 11px;
        color: var(--color-ink-mute);
        margin-top: 10px;
      }

      /* パンくずリスト */
      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--color-ink-mute);
        margin-bottom: 20px;
        flex-wrap: wrap;
      }
      .breadcrumb a {
        color: var(--color-ink-mute);
        text-decoration: none;
      }
      .breadcrumb a:hover { color: var(--color-accent); }
      .breadcrumb-sep { opacity: 0.5; }
      .breadcrumb span:last-child {
        color: var(--color-ink-soft);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 200px;
      }

      /* 目次 */
      .toc {
        background: var(--color-paper-light);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin: 0 0 36px;
      }
      .toc-title {
        font-family: var(--font-serif);
        font-size: 14px;
        font-weight: 600;
        color: var(--color-ink);
        margin-bottom: 12px;
        letter-spacing: 0.04em;
      }
      .toc-list {
        margin: 0;
        padding-left: 1.2em;
        list-style: decimal;
      }
      .toc-list li {
        font-size: 13px;
        line-height: 1.6;
        margin-bottom: 6px;
        color: var(--color-ink);
      }
      .toc-list li::before { display: none; }
      .toc-list li::marker { color: var(--color-accent); }
      .toc-list a {
        color: var(--color-ink-soft);
        text-decoration: none;
      }
      .toc-list a:hover { color: var(--color-accent); }
      .toc-h3 { padding-left: 1em; list-style: none; }
      .toc-h3::before { content: '– '; color: var(--color-ink-mute); }

      /* 読了時間 */
      .reading-time {
        font-size: 11px;
        color: var(--color-ink-mute);
        letter-spacing: 0.03em;
      }

      /* シェアボタン */
      .share-buttons {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 40px 0 0;
        flex-wrap: wrap;
      }
      .share-label {
        font-size: 12px;
        color: var(--color-ink-mute);
        letter-spacing: 0.05em;
      }
      .share-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 16px;
        border-radius: var(--radius-md);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.05em;
        cursor: pointer;
        text-decoration: none;
        transition: opacity var(--duration-base) var(--easing-standard);
        border: none;
        font-family: var(--font-sans);
      }
      .share-btn:hover { opacity: 0.8; }
      .share-x { background: #000; color: #fff; }
      .share-copy { background: var(--color-surface-warm); color: var(--color-ink); border: 1px solid var(--color-border); }

      /* 著者カード */
      .author-card {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        background: var(--color-paper-light);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px;
        margin: 48px 0 0;
      }
      .author-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
      }
      .author-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .author-info { flex: 1; }
      .author-name {
        font-family: var(--font-serif);
        font-size: 15px;
        color: var(--color-ink);
        margin-bottom: 4px;
      }
      .author-handle {
        font-size: 11px;
        color: var(--color-ink-mute);
        font-family: var(--font-mono);
        margin-bottom: 8px;
      }
      .author-bio {
        font-size: 12px;
        color: var(--color-ink-soft);
        line-height: 1.75;
        margin: 0;
      }

      /* 関連記事ボックス */
      .related-box {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 18px 22px;
        margin: 32px 0;
        background: var(--color-surface);
      }
      .related-box .box-title {
        font-size: 11px;
        color: var(--color-ink-mute);
        letter-spacing: 0.15em;
        margin-bottom: 12px;
      }
      .related-box a {
        display: block;
        font-size: 14px;
        color: var(--color-ink);
        text-decoration: none;
        padding: 6px 0;
        border-top: 1px solid var(--color-border-soft);
        transition: color var(--duration-base) var(--easing-standard);
      }
      .related-box a:first-of-type { border-top: none; }
      .related-box a:hover { color: var(--color-accent); }

      /* Sidebar */
      .sidebar {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .sidebar-card {
        background: var(--color-paper-light);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 20px;
      }
      .sidebar-profile { text-align: center; }
      .avatar {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        margin: 0 auto 10px;
        overflow: hidden;
      }
      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .profile-name {
        font-family: var(--font-serif);
        font-size: 18px;
        color: var(--color-ink);
        letter-spacing: 0.05em;
      }
      .profile-handle {
        font-size: 11px;
        color: var(--color-ink-mute);
        letter-spacing: 0.05em;
        margin-top: 2px;
        font-family: var(--font-mono);
      }
      .profile-bio {
        font-size: 12px;
        color: var(--color-ink-soft);
        line-height: 1.75;
        margin: 12px 0 16px;
      }
      .btn-outline {
        display: block;
        box-sizing: border-box;
        background: transparent;
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius-md);
        padding: 8px 0;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.08em;
        color: var(--color-ink);
        text-align: center;
        text-decoration: none;
        transition: background var(--duration-base) var(--easing-standard);
      }
      .btn-outline:hover { background: var(--color-surface-warm); color: var(--color-ink); }

      .newsletter { background: var(--color-surface-warm); }
      .newsletter-title {
        font-family: var(--font-serif);
        font-size: 16px;
        color: var(--color-ink);
        margin-bottom: 4px;
      }
      .newsletter-desc {
        font-size: 11px;
        color: var(--color-ink-soft);
        line-height: 1.7;
        margin-bottom: 12px;
      }
      .newsletter-form { display: flex; gap: 6px; }
      .newsletter-form input {
        flex: 1;
        padding: 9px 12px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        font-size: 12px;
        font-family: var(--font-sans);
        color: var(--color-ink);
      }
      .newsletter-form input:focus { outline: none; border-color: var(--color-accent); }
      .newsletter-form button {
        background: var(--color-accent);
        color: var(--color-paper-light);
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.08em;
        cursor: pointer;
        font-family: var(--font-sans);
      }
      .newsletter-form button:hover { background: var(--color-accent-hover); }

      @media (max-width: 768px) {
        .layout {
          grid-template-columns: 1fr;
          padding: 24px 16px 40px;
        }
        .article-title { font-size: 24px; }
        .sidebar { display: none; }
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="layout">
      <article>
        <!-- パンくずリスト -->
        <nav class="breadcrumb" aria-label="パンくずリスト">
          <a href="/">ホーム</a>
          <span class="breadcrumb-sep">›</span>
          <a href={`/?category=${category}`}>{cat.label}</a>
          <span class="breadcrumb-sep">›</span>
          <span>{title}</span>
        </nav>

        <div class="article-meta">
          <span class="tag" style={`background:${cat.bg};color:${cat.color}`}>
            <span class="tag-dot" style={`background:${cat.dot}`}></span>
            {cat.label}
          </span>
          <span>{dateStr}</span>
          {readingTime && <span class="reading-time">📖 約{readingTime}分</span>}
        </div>
        <h1 class="article-title">{title}</h1>

        <!-- 目次 -->
        {tocHeadings.length >= 3 && (
          <nav class="toc">
            <div class="toc-title">📋 目次</div>
            <ol class="toc-list">
              {tocHeadings.map((h: {depth: number; slug: string; text: string}) => (
                <li class={h.depth === 3 ? 'toc-h3' : ''}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        )}
        <div class="prose">
          <slot />
        </div>

        <!-- シェアボタン -->
        <div class="share-buttons">
          <span class="share-label">この記事をシェア</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.toString())}`} target="_blank" rel="noopener noreferrer" class="share-btn share-x">𝕏 ポスト</a>
          <button class="share-btn share-copy" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='コピーしました！';setTimeout(()=>{this.textContent='🔗 URLコピー'},2000)})">🔗 URLコピー</button>
        </div>

        <!-- 著者カード -->
        <div class="author-card">
          <div class="author-avatar"><img src="/avatar.png" alt="まこも" /></div>
          <div class="author-info">
            <div class="author-name">まこも</div>
            <div class="author-handle">@macomo_note</div>
            <p class="author-bio">30代専業主婦・男三兄弟の母。資産3,000万円突破。FP2級取得・簿記3級勉強中・宅建受験予定。家計管理と長期投資で、普通の主婦でもできる資産形成を発信しています。</p>
          </div>
        </div>
      </article>

      <aside class="sidebar">
        <div class="sidebar-card sidebar-profile">
          <div class="avatar"><img src="/avatar.png" alt="まこも" /></div>
          <div class="profile-name">まこも</div>
          <div class="profile-handle">@macomo_note</div>
          <p class="profile-bio">30代専業主婦・男三兄弟の母。資産3,000万円突破。FP2級取得・簿記3級勉強中・宅建受験予定。</p>
          <a href="/about" class="btn-outline">プロフィールを見る ›</a>
        </div>

        <div class="sidebar-card newsletter">
          <div class="newsletter-title">新着記事をメールで受け取る</div>
          <p class="newsletter-desc">家計・投資・資格の新記事をお届けします。登録無料・いつでも解除OK。</p>
          <div class="newsletter-form">
            <input type="email" placeholder="you@example.com" />
            <button type="button">登録</button>
          </div>
        </div>
      </aside>
    </div>
    <Footer />
  </body>
</html>
