---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const catMap: Record<string, { label: string; bg: string; color: string; dot: string }> = {
  money: { label: 'お金', bg: '#F0E4D4', color: '#8A6A3E', dot: '#C49A6A' },
  study: { label: '学び', bg: '#DDE3D4', color: '#4F6041', dot: '#7A8B6A' },
  family: { label: '子育て', bg: '#EDDCDC', color: '#7A5252', dot: '#A67F7F' },
};

function getCat(post: any) {
  const cat = post.data.category || 'money';
  return catMap[cat] || catMap.money;
}

const catCounts = {
  money: posts.filter(p => (p.data.category || 'money') === 'money').length,
  study: posts.filter(p => p.data.category === 'study').length,
  family: posts.filter(p => p.data.category === 'family').length,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero -->
      <section class="hero">
        <h1>ムリせず、整う<span class="accent-dot">。</span></h1>
        <p class="hero-sub">お金・子育て・学びで、整う暮らしを。<br>専業主婦まこもの、等身大の資産形成と日常記録。</p>
      </section>

      <!-- 2-column layout -->
      <div class="layout">
        <div class="main-col">
          <div class="section-label">LATEST POSTS</div>

          {posts.length > 0 && (
            <article class="card card-large">
              <a href={`/blog/${posts[0].id}/`}>
                <div class="card-meta">
                  {(() => {
                    const c = getCat(posts[0]);
                    return (
                      <span class="tag" style={`background:${c.bg};color:${c.color}`}>
                        <span class="tag-dot" style={`background:${c.dot}`}></span>
                        {c.label}
                      </span>
                    );
                  })()}
                  <span class="meta-date">{posts[0].data.pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'2-digit',day:'2-digit'}).replace(/\//g, '.')}</span>
                </div>
                <h2 class="card-title large">{posts[0].data.title}</h2>
                {posts[0].data.description && (
                  <p class="card-excerpt">{posts[0].data.description}</p>
                )}
              </a>
            </article>
          )}

          <div class="card-grid">
            {posts.slice(1).map(post => {
              const c = getCat(post);
              return (
                <article class="card">
                  <a href={`/blog/${post.id}/`}>
                    <div class="card-meta">
                      <span class="tag" style={`background:${c.bg};color:${c.color}`}>
                        <span class="tag-dot" style={`background:${c.dot}`}></span>
                        {c.label}
                      </span>
                      <span class="meta-date">{post.data.pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'2-digit',day:'2-digit'}).replace(/\//g, '.')}</span>
                    </div>
                    <h3 class="card-title">{post.data.title}</h3>
                    {post.data.description && (
                      <p class="card-excerpt small">{post.data.description}</p>
                    )}
                  </a>
                </article>
              );
            })}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
          <!-- Profile -->
          <div class="sidebar-card sidebar-profile">
            <div class="avatar">ま</div>
            <div class="profile-name">まこも</div>
            <div class="profile-handle">@macomo_note</div>
            <p class="profile-bio">30代専業主婦・男三兄弟の母。資産3,000万円突破。FP2級取得・簿記3級勉強中・宅建受験予定。</p>
            <p class="profile-gets">このブログでは「普通の主婦でもできる」お金の増やし方と暮らしの工夫を発信しています。</p>
            <a href="/about" class="btn-outline">プロフィールを見る ›</a>
          </div>

          <!-- Categories -->
          <div class="sidebar-card">
            <div class="sidebar-label">CATEGORIES</div>
            <div class="cat-item">
              <div>
                <div class="cat-name">お金</div>
                <div class="cat-desc">資産運用・節約・家計公開</div>
              </div>
              <span class="cat-count">{catCounts.money}</span>
            </div>
            <div class="cat-item">
              <div>
                <div class="cat-name">学び</div>
                <div class="cat-desc">資格勉強・読書・学習記録</div>
              </div>
              <span class="cat-count">{catCounts.study}</span>
            </div>
            <div class="cat-item">
              <div>
                <div class="cat-name">子育て</div>
                <div class="cat-desc">育児・暮らし・男三兄弟</div>
              </div>
              <span class="cat-count">{catCounts.family}</span>
            </div>
          </div>

          <!-- Newsletter -->
          <div class="sidebar-card newsletter">
            <div class="newsletter-title">新着記事をメールで</div>
            <p class="newsletter-desc">新しい記事を書いたらお知らせします。いつでも解除できます。</p>
            <div class="newsletter-form">
              <input type="email" placeholder="you@example.com" />
              <button type="button">登録</button>
            </div>
          </div>
        </aside>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main { padding-bottom: 0; }

  /* Hero */
  .hero {
    max-width: var(--layout-max);
    margin: 0 auto;
    padding: 60px 24px 40px;
    text-align: center;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: 0.08em;
    line-height: 1.35;
  }
  .accent-dot { color: var(--color-accent); }
  .hero-sub {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
    line-height: 1.8;
    margin-top: 16px;
  }

  /* Layout */
  .layout {
    max-width: var(--layout-max);
    margin: 0 auto;
    padding: 0 24px 60px;
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: 40px;
  }

  /* Section label */
  .section-label {
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.2em;
    margin-bottom: 18px;
  }

  /* Cards */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    transition: border-color var(--duration-base) var(--easing-standard),
                background var(--duration-base) var(--easing-standard);
    margin-bottom: 0;
  }
  .card:hover {
    border-color: var(--color-border-strong);
    background: var(--color-paper-light);
  }
  .card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card a:hover { color: inherit; }
  .card-large {
    padding: 28px;
    margin-bottom: 16px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* Card internals */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: var(--radius-xs);
  }
  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .meta-date {
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: 0.03em;
    line-height: 1.5;
    margin: 0 0 8px;
  }
  .card-title.large {
    font-size: 26px;
  }
  .card-excerpt {
    font-size: 14px;
    color: var(--color-ink-soft);
    line-height: 1.8;
    margin: 0;
  }
  .card-excerpt.small { font-size: 13px; }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .sidebar-card {
    background: var(--color-paper-light);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px;
  }
  .sidebar-label {
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.15em;
    margin-bottom: 14px;
  }

  /* Profile */
  .sidebar-profile { text-align: center; }
  .avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, #E8D6C5, #F0E4D4);
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 26px;
    color: #8A6A3E;
  }
  .profile-name {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-ink);
    letter-spacing: 0.05em;
  }
  .profile-handle {
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
    margin-top: 2px;
    font-family: var(--font-mono);
  }
  .profile-bio {
    font-size: 12px;
    color: var(--color-ink);
    line-height: 1.75;
    margin: 12px 0 8px;
  }
  .profile-gets {
    font-size: 11px;
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin: 0 0 14px;
    padding: 8px 10px;
    background: var(--color-surface-warm);
    border-radius: var(--radius-sm);
    text-align: left;
  }
  .btn-outline {
    display: block;
    width: 100%;
    box-sizing: border-box;
    background: transparent;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: 8px 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-ink);
    text-align: center;
    text-decoration: none;
    transition: background var(--duration-base) var(--easing-standard);
  }
  .btn-outline:hover {
    background: var(--color-surface-warm);
    color: var(--color-ink);
  }

  /* Categories */
  .cat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-top: 1px solid var(--color-border-soft);
  }
  .cat-item:first-of-type { border-top: none; }
  .cat-name {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--color-ink);
  }
  .cat-desc {
    font-size: 11px;
    color: var(--color-ink-soft);
    margin-top: 2px;
  }
  .cat-count {
    font-family: var(--font-num);
    font-size: 18px;
    color: var(--color-accent);
    font-weight: 500;
    flex-shrink: 0;
  }

  /* Newsletter */
  .newsletter { background: var(--color-surface-warm); }
  .newsletter-title {
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--color-ink);
    margin-bottom: 4px;
  }
  .newsletter-desc {
    font-size: 11px;
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .newsletter-form {
    display: flex;
    gap: 6px;
  }
  .newsletter-form input {
    flex: 1;
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    font-size: 12px;
    font-family: var(--font-sans);
    color: var(--color-ink);
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .newsletter-form button {
    background: var(--color-accent);
    color: var(--color-paper-light);
    border: none;
    border-radius: var(--radius-sm);
    padding: 9px 16px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background var(--duration-base) var(--easing-standard);
  }
  .newsletter-form button:hover {
    background: var(--color-accent-hover);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .layout {
      grid-template-columns: 1fr;
      padding: 0 16px 40px;
    }
    .hero { padding: 40px 16px 24px; }
    .hero h1 { font-size: 2rem; }
    .card-grid { grid-template-columns: 1fr; }
    .sidebar { display: none; }
  }
</style>
