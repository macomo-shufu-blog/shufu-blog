---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p>3人の男の子を育てながら、お金・子育て・学びのことをゆるく発信しています。</p>
			</section>
			<section class="posts">
				<h2>新着記事</h2>
				<ul>
					{posts.map(post => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="title">{post.data.title}</span>
								<span class="date">{post.data.pubDate.toLocaleDateString('ja-JP')}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		background: #EEE8E0;
		border-radius: 12px;
		padding: 1.2em 1.5em;
		margin-bottom: 2em;
		color: #5C514C;
		font-size: 0.95em;
	}
	h2 {
		font-size: 1.3em;
		color: #3A2E2A;
		border-bottom: 2px solid #EEE8E0;
		padding-bottom: 0.4em;
		margin-bottom: 1em;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	li {
		border-bottom: 1px solid #EEE8E0;
	}
	li a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1em 0.2em;
		text-decoration: none;
		color: #3A2E2A;
		gap: 1em;
	}
	li a:hover .title {
		color: #C4956A;
	}
	.title {
		font-size: 1em;
		line-height: 1.4;
	}
	.date {
		font-size: 0.8em;
		color: #A89990;
		white-space: nowrap;
	}
</style>
