---
const year = new Date().getFullYear();
---

<footer>
  <div class="logo">macomo<span class="dot">·</span>note</div>
  <div class="tagline">MURISEZU TOTONOU</div>
  <nav>
    <a href="/about">プロフィール</a>
    <a href="#">プライバシーポリシー</a>
    <a href="#">お問い合わせ</a>
  </nav>
  <div class="copy">© {year} macomo note</div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 40px 24px 60px;
    margin-top: 80px;
    text-align: center;
    background: var(--color-paper);
  }
  .logo {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-ink);
    letter-spacing: 0.06em;
  }
  .dot { color: var(--color-accent); }
  .tagline {
    font-size: 11px;
    color: var(--color-ink-mute);
    letter-spacing: 0.1em;
    margin-top: 6px;
  }
  nav {
    display: flex;
    gap: 24px;
    justify-content: center;
    margin-top: 20px;
  }
  nav a {
    font-size: 12px;
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  nav a:hover { color: var(--color-accent); }
  .copy {
    font-size: 10px;
    color: var(--color-ink-mute);
    margin-top: 24px;
    letter-spacing: 0.1em;
  }
</style>
