---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="banner">
		<img src="/banner.svg" alt={SITE_TITLE} />
	</div>
	<nav>
		<div class="internal-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">ブログ</HeaderLink>
			<HeaderLink href="/about">このブログについて</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: #F7F5F2;
		box-shadow: 0 2px 8px rgba(0,0,0,5%);
	}
	.banner {
		width: 100%;
		max-height: 200px;
		overflow: hidden;
	}
	.banner img {
		width: 100%;
		height: auto;
		display: block;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 1em;
		background: #F7F5F2;
		border-top: 1px solid #EEE8E0;
	}
	.internal-links {
		display: flex;
		gap: 0.5em;
	}
	nav a {
		padding: 0.8em 1em;
		color: #3A2E2A;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
	}
	nav a.active {
		border-bottom-color: #C4956A;
	}
</style>
